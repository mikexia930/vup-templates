{
  "name": "@vup/ui-mobile",
  "description": "Mobile UI wrapper based on Ionic Vue",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.js",
    "lint:fix": "eslint src/ --ext .ts,.js --fix",
    "format": "prettier --write \"src/**/*.{js,ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,json}\""
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@ionic/vue": "^8.7.7",
    "ionicons": "^7.4.0"
  }
}
