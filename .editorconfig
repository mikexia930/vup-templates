# EditorConfig 统一所有编辑器的基础格式
# https://editorconfig.org

root = true

# 通用规则：所有文件
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

# Markdown：保留行尾空格（用于硬换行），关闭最大行宽
[*.md]
trim_trailing_whitespace = false
max_line_length = 80

# Python：4 空格缩进，PEP 8
[*.py]
indent_size = 4
max_line_length = 88

# Go：使用 tab 缩进（Go 官方约定）
[*.go]
indent_style = tab

# Makefile：必须用 tab
[Makefile]
indent_style = tab

# YAML：明确 2 空格（避免歧义）
[*.{yml,yaml}]
indent_size = 2

# JSON：2 空格
[*.json]
indent_size = 2

# Shell 脚本：2 空格（与项目其他文件保持一致）
[*.sh]
indent_size = 2

# 锁文件：不强制
[{pnpm-lock.yaml,package-lock.json,yarn.lock,poetry.lock,Cargo.lock}]
indent_size = unset
max_line_length = unset